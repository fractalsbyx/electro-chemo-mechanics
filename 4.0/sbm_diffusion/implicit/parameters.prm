subsection Rectangular mesh
  set x size = 100
  set y size = 100
  set z size = 100
end

set global refinement = 7
set max refinement = 7
set min refinement = 1
set mesh adaptivity = true

subsection refinement criterion: 0
  set variables         = psi
  set type              = value
  set value lower bound = 1e-3
  set value upper bound = 2
end

set time step = 1.0
set number steps = 100000

subsection output
  set condition = EQUAL_SPACING
  set number = 100
  set file type = vtu
end

set Model constant c0 = 1.0, DOUBLE
set Model constant offset = 1e-2, DOUBLE

subsection linear solver parameters: 0
  set solver_ids               = 0
  set solver type              = bicgstab
  set max iterations           = 10000
  set tolerance type           = RMSEPerField
  set tolerance value          = 1.0e-6
  set preconditioner           = Chebyshev

  subsection Chebyshev
    set eigenvalue cg iterations = 10
    set smoother degree = 5
    set smoothing range = 0.0001
  end
end 

subsection newton solver parameters: 0
  set solver_ids               = 0
  set max iterations           = 100
  set step size                = 1.0
  set tolerance value          = 1.0e-6
end