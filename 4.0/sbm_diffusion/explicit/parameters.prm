subsection Rectangular mesh
  set x size = 100
  set y size = 100
  set z size = 100
end

set global refinement = 7

set time step = 1.0e-2
set number steps = 100000

subsection output
  set condition = EQUAL_SPACING
  set number = 100
  set file type = vtu
end

set Model constant c0 = 1.0, DOUBLE
set Model constant c_ref = 0.1, DOUBLE
set Model constant diffusivity = 0.1, DOUBLE
set Model constant offset = 1e-2, DOUBLE
set Model constant width = 2.0, DOUBLE